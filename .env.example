# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# MongoDB Atlas connection string.
# Atlas dashboard -> Database -> Connect -> Drivers -> copy the connection string,
# then swap <password> for your database user's real password.
MONGO_URL=mongodb+srv://<db-username>:<db-password>@<cluster-name>.mongodb.net/ekalavya?retryWrites=true&w=majority

# Database name (must match the db name used in your Atlas connection).
DB_NAME=ekalavya

# Secret used to sign JWT session tokens. Generate a real one with:
#   openssl rand -hex 32
JWT_SECRET=

# Initial admin account — only used ONCE, on first startup, to create the very first
# login if the users collection is empty. After that first login, create/manage
# additional admin & volunteer accounts from the admin panel itself (Users tab).
# Pick a real username here — do not use "admin".
ADMIN_USERNAME=
ADMIN_PASSWORD=

# YouTube upload credentials for video feedback. Optional — video feedback
# submissions are disabled (with a clear message to the user) until these are
# set. Generate them by running scripts/youtube_oauth_setup.py once, locally,
# logged in as the Google account that manages the EPA YouTube channel.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
